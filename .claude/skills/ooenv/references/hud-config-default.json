{
  "preset": "minimal",
  "elements": {
    "omcLabel": true,
    "ralph": true,
    "prdStory": false,
    "activeSkills": false,
    "lastSkill": false,
    "contextBar": true,
    "agents": true,
    "backgroundTasks": true,
    "todos": true,
    "model": true,
    "modelFormat": "short",
    "rateLimits": true,
    "showCache": false,
    "showCost": false,
    "maxOutputLines": 3
  },
  "layout": {
    "line1": ["hostname", "cwd", "gitRepo", "gitBranch", "gitStatus", "apiKeySource", "profile"],
    "main": ["omcLabel", "model", "rateLimits", "ralph", "contextBar", "background"]
  },
  "thresholds": {
    "contextWarning": 70,
    "contextCritical": 85,
    "ralphWarning": 7
  }
}
